# Required: LLM provider override for simple single-provider setups.
# If you use backend/data/config.json with llm_fallback_chain, that file is the runtime source of truth.
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-oss-20b:free
LLM_API_KEY=

# Optional: custom API base for compatible gateways / self-hosted endpoints.
# LLM_API_BASE=

# Backend server binding.
HOST=127.0.0.1
BACKEND_PORT=8001
# PORT=
LOG_LEVEL=INFO
LOG_LLM=WARNING
DATA_DIR=data

# Frontend public URL used by backend PDF routes.
FRONTEND_BASE_URL=http://localhost:3000

# Frontend / Chainlit backend target.
BACKEND_URL=http://127.0.0.1:8001
CHAINLIT_AUTH_SECRET=change-this-to-a-long-random-string
CHAINLIT_APP_USERNAME=local-user
CHAINLIT_APP_PASSWORD=job-mediator-123
CHAINLIT_APP_DISPLAY_NAME=Local User
CHAINLIT_AUTO_LOGIN=true

# Optional local frontend storage overrides.
# CHAINLIT_APP_DATA_DIR=frontend/data
# CHAINLIT_APP_PUBLIC_DIR=frontend/public

# Optional job-search fallback configuration.
JOB_SEARCH_FALLBACK_PROVIDER=auto
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
JOB_SEARCH_FALLBACK_COUNT=8

# Optional notifications for scheduled scan.
# FEISHU_WEBHOOK_URL=
